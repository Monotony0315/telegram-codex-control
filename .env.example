TELEGRAM_BOT_TOKEN=123456:replace-me
ALLOWED_USER_ID=123456789
ALLOWED_CHAT_ID=123456789
WORKSPACE_ROOT=$HOME/Projects
UPLOAD_DIR=.data/uploads
DB_PATH=.data/state.db
AUDIT_LOG_PATH=.data/audit.jsonl
CODEX_COMMAND=codex
# Optional fallback Codex command used when primary execution fails with DNS/network-restriction patterns.
# Example: CODEX_COMMAND_FALLBACK=/usr/local/bin/codex
CODEX_COMMAND_FALLBACK=
# Optional Rust live-core helper command used for normalized /chat event streaming.
# Example: CODEX_LIVE_CORE_COMMAND=/usr/local/bin/tgcc-live-core
CODEX_LIVE_CORE_COMMAND=
TELEGRAM_INTERACTIVE_MODE=true
COMMAND_POLICY_PATH=
TELEGRAM_TRANSPORT=polling
TELEGRAM_WEBHOOK_PUBLIC_URL=
TELEGRAM_WEBHOOK_LISTEN_HOST=127.0.0.1
TELEGRAM_WEBHOOK_LISTEN_PORT=8080
TELEGRAM_WEBHOOK_PATH=/telegram/webhook
TELEGRAM_WEBHOOK_SECRET_TOKEN=
POLL_TIMEOUT_SECONDS=30
POLL_RETRY_BASE_SECONDS=1.0
POLL_RETRY_MAX_SECONDS=30.0
JOB_TIMEOUT_SECONDS=7200
CHAT_TURN_TIMEOUT_SECONDS=1800
CHAT_TURN_PROGRESS_TIMEOUT_SECONDS=300
CHAT_TURN_RETRY_COUNT=1
CHAT_TURN_RESET_SESSION_ON_TIMEOUT=true
SUBPROCESS_ENV_ALLOWLIST=
SUBPROCESS_ENV_PREFIX_ALLOWLIST=
# Optional override for Codex subprocess HOME. Default: inherit current HOME.
# SUBPROCESS_HOME=
CONFIRMATION_TTL_SECONDS=300
MESSAGE_CHUNK_SIZE=3500
MAX_DOWNLOAD_FILE_SIZE_BYTES=5242880
MAX_UPLOAD_FILE_SIZE_BYTES=5242880
TELEGRAM_API_BASE=https://api.telegram.org
